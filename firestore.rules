rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null && 
        (request.auth.token.email == 'harshillakhani2264@gmail.com' || request.auth.token.email == 'navadiyadhruvit@gmail.com');
    }
  }
}
